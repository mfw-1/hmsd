@model HMSD.Data.Student

@{
    ViewData["Title"] = "Edit Student";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Edit Student</h2>
            <small class="text-muted">Update existing student information</small>
        </div>

        <a asp-action="Index" class="btn btn-light border shadow-sm">
            ← Back
        </a>
    </div>

    <!-- Main Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4 p-md-5">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <input type="hidden" asp-for="Id" />

                <!-- SECTION 1 -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Identity Information</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="RegistrationNo" class="form-label fw-semibold"></label>
                            <input asp-for="RegistrationNo"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CNIC" class="form-label fw-semibold"></label>
                            <input asp-for="CNIC"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label fw-semibold"></label>
                            <input asp-for="FirstName"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label fw-semibold"></label>
                            <input asp-for="LastName"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Gender" class="form-label fw-semibold"></label>
                            <input asp-for="Gender"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label fw-semibold"></label>
                            <input asp-for="DateOfBirth"
                                   type="date"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SECTION 2 -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Contact Information</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label fw-semibold"></label>
                            <input asp-for="Phone"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Address" class="form-label fw-semibold"></label>
                            <input asp-for="Address"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="City" class="form-label fw-semibold"></label>
                            <input asp-for="City"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SECTION 3 -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Academic Information</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="InstituteName" class="form-label fw-semibold"></label>
                            <input asp-for="InstituteName"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label fw-semibold"></label>
                            <input asp-for="Department"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Semester" class="form-label fw-semibold"></label>
                            <input asp-for="Semester"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SECTION 4 -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Guardian Information</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="GuardianName" class="form-label fw-semibold"></label>
                            <input asp-for="GuardianName"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="GuardianPhone" class="form-label fw-semibold"></label>
                            <input asp-for="GuardianPhone"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EmergencyContact" class="form-label fw-semibold"></label>
                            <input asp-for="EmergencyContact"
                                   class="form-control form-control-lg shadow-sm" />
                        </div>

                    </div>
                </div>

                <!-- ACTIONS -->
                <div class="d-flex justify-content-end mt-4">
                    <a asp-action="Index" class="btn btn-light border shadow-sm me-2">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                        Save Changes
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>