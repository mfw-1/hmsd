<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Hostel Management</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

    <style>
            body {
                background: #f4f6f9;
            }

            /* Sidebar */
            .sidebar {
                width: 250px;
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                background: #1f2d3d;
                color: white;
                padding-top: 20px;
            }

                .sidebar a {
                    color: #c2c7d0;
                    display: block;
                    padding: 12px 20px;
                    text-decoration: none;
                    border-radius: 5px;
                    margin: 5px 10px;
                }

                    .sidebar a:hover {
                        background: #343a40;
                        color: white;
                    }

            .main-content {
                margin-left: 260px;
                padding: 20px;
            }

            .topbar {
                background: white;
                padding: 10px 20px;
                border-radius: 10px;
                margin-bottom: 20px;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            .card-box {
                border-radius: 12px;
                padding: 20px;
                color: white;
            }

            .bg-blue {
                background: #17a2b8;
            }

            .bg-green {
                background: #28a745;
            }

            .bg-orange {
                background: #fd7e14;
            }

            .bg-red {
                background: #dc3545;
            }
    </style>
</head>

<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <h4 class="text-center mb-4">
            <i class="fa fa-building"></i> Hostel MS
        </h4>

        <a asp-controller="Dashboard" asp-action="Index">
            <i class="fa fa-home"></i> Dashboard
        </a>

        <a asp-controller="Students" asp-action="Index">
            <i class="fa fa-user-graduate"></i> Students
        </a>

        <a asp-controller="Rooms" asp-action="Index">
            <i class="fa fa-bed"></i> Rooms
        </a>

        <a asp-controller="Allocations" asp-action="Index">
            <i class="fa fa-handshake"></i> Allocations
        </a>

        <a asp-controller="Payments" asp-action="Index">
            <i class="fa fa-money-bill"></i> Payments
        </a>

        <a asp-controller="Complaints" asp-action="Index">
            <i class="fa fa-exclamation-circle"></i> Complaints
        </a>

        <a asp-controller="Notices" asp-action="Index">
            <i class="fa fa-bell"></i> Notices
        </a>
    </div>

    <!-- Main Content -->
    <div class="main-content">

        <!-- Topbar -->
        <div class="topbar shadow-sm">
            <h5 class="m-0">@ViewData["Title"]</h5>

            <div>
                <i class="fa fa-user-circle"></i> Admin
            </div>
        </div>

        <!-- Page Content -->
        @RenderBody()

    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>