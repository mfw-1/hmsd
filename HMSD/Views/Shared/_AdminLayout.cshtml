@using Microsoft.AspNetCore.Identity
@using HMSD.Data

@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "Index";

    // Determine if the active route is a processing layout (Create/Edit/Delete/Details view)
    bool isFormView = currentAction == "Create" || currentAction == "Edit" || currentAction == "Delete" || currentAction == "Details";
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Hostel Management System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

    <style>
            /* Enterprise CSS System Tokens */
            :root, [data-bs-theme="light"] {
                --bg-body: #f8fafc;
                --bg-topbar: rgba(255, 255, 255, 0.8);
                --bg-sidebar: #0f172a;
                --text-main: #0f172a;
                --text-muted: #64748b;
                --border-color: #e2e8f0;
                --card-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px -1px rgba(0, 0, 0, 0.05);
                --sidebar-width: 260px;
            }

            [data-bs-theme="dark"] {
                --bg-body: #090d16;
                --bg-topbar: rgba(17, 24, 39, 0.8);
                --bg-sidebar: #111827;
                --text-main: #f8fafc;
                --text-muted: #94a3b8;
                --border-color: #1f2937;
                --card-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.3), 0 1px 2px -1px rgba(0, 0, 0, 0.3);
            }

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                background: var(--bg-body) !important;
                color: var(--text-main);
                font-family: 'Inter', system-ui, -apple-system, sans-serif;
                overflow-x: hidden;
                transition: background 0.25s ease, color 0.25s ease;
            }

            /* ==========================================
                                    SIDEBAR ARCHITECTURE
                       ========================================== */
            .sidebar {
                width: var(--sidebar-width);
                height: 100vh;
                position: fixed;
                left: 0;
                top: 0;
                background: var(--bg-sidebar);
                color: #f8fafc;
                padding: 24px 0;
                z-index: 1010;
                overflow-y: auto;
                transition: width 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .brand {
                padding: 0 24px 24px;
                border-bottom: 1px solid rgba(255, 255, 255, 0.06);
                margin-bottom: 20px;
                display: flex;
                flex-direction: column;
                gap: 4px;
            }

                .brand h3 {
                    font-size: 18px;
                    font-weight: 700;
                    margin: 0;
                    letter-spacing: -0.5px;
                    display: flex;
                    align-items: center;
                    gap: 10px;
                }

                .brand span {
                    color: #64748b;
                    font-size: 12px;
                    font-weight: 500;
                    white-space: nowrap;
                    transition: opacity 0.2s;
                }

            .menu-title {
                color: #475569;
                font-size: 11px;
                font-weight: 700;
                text-transform: uppercase;
                padding: 12px 24px 6px;
                letter-spacing: 0.05em;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                color: #94a3b8;
                text-decoration: none;
                padding: 10px 16px;
                margin: 4px 16px;
                border-radius: 8px;
                transition: all 0.2s ease;
                font-size: 14px;
                font-weight: 500;
            }

                .sidebar a:hover {
                    background: rgba(255, 255, 255, 0.04);
                    color: #f8fafc;
                }

                .sidebar a.active {
                    background: #2563eb;
                    color: white;
                    font-weight: 600;
                    box-shadow: 0 4px 12px rgba(37, 99, 235, 0.25);
                }

                .sidebar a i {
                    width: 20px;
                    text-align: center;
                    font-size: 16px;
                }

            /* Collapsed Sidebar State */
            body.sidebar-collapsed {
                --sidebar-width: 78px;
            }

                body.sidebar-collapsed .brand span,
                body.sidebar-collapsed .menu-title,
                body.sidebar-collapsed .menu-text {
                    display: none !important;
                }

                body.sidebar-collapsed .brand h3 {
                    justify-content: center;
                }

                body.sidebar-collapsed .sidebar a {
                    justify-content: center;
                    padding: 12px;
                }

            /* ==========================================
                                    MAIN WORKSPACE
                       ========================================== */
            .main-content {
                margin-left: var(--sidebar-width);
                min-height: 100vh;
                padding: 32px;
                transition: margin-left 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            }

            /* Topbar Module */
            .topbar {
                background: var(--bg-topbar);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                border: 1px solid var(--border-color);
                border-radius: 14px;
                padding: 16px 24px;
                margin-bottom: 32px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                box-shadow: var(--card-shadow);
            }

            .page-title h4 {
                margin: 0;
                font-size: 20px;
                font-weight: 700;
                letter-spacing: -0.5px;
            }

            .page-title span {
                font-size: 13px;
                color: var(--text-muted);
            }

            /* Dropdowns & Navigation Controls */
            .user-dropdown .dropdown-toggle {
                text-decoration: none;
                color: var(--text-main);
                display: flex;
                align-items: center;
                gap: 12px;
                font-weight: 600;
                font-size: 14px;
            }

            .user-avatar {
                width: 36px;
                height: 36px;
                background: linear-gradient(135deg, #3b82f6, #1d4ed8);
                border-radius: 8px;
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 14px;
                font-weight: bold;
            }

            .dropdown-menu {
                border: 1px solid var(--border-color);
                background: var(--bg-topbar);
                backdrop-filter: blur(16px);
                border-radius: 12px;
                padding: 6px;
                box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
            }

            .dropdown-item {
                border-radius: 6px;
                padding: 8px 12px;
                font-size: 13.5px;
                font-weight: 500;
                color: var(--text-main);
            }

            /* Data Containers - Strict Rectangular System */
            .table-responsive {
                background: var(--bg-topbar);
                border: 1px solid var(--border-color);
                box-shadow: var(--card-shadow);
                border-radius: 0 !important; /* Forces flat geometric sharpness */
            }

            table.table {
                border-radius: 0 !important;
            }

            /* ==========================================
                              DYNAMIC ADVANCED INPUT SYSTEM
                       ========================================== */
            .form-engine-card {
                background: var(--bg-topbar);
                border: 1px solid var(--border-color);
                box-shadow: var(--card-shadow);
                padding: 32px;
                margin-top: 10px;
            }

            .form-label {
                font-size: 12.5px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: 0.03em;
                color: var(--text-muted);
                margin-bottom: 6px;
            }

            .form-control:focus, .form-select:focus {
                border-color: #2563eb !important;
                box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15) !important;
            }

            .text-danger.field-validation-error {
                font-size: 12px;
                font-weight: 500;
                margin-top: 4px;
                display: block;
            }

            /* Scrollbar styling */
            ::-webkit-scrollbar {
                width: 6px;
                height: 6px;
            }

            ::-webkit-scrollbar-track {
                background: transparent;
            }

            ::-webkit-scrollbar-thumb {
                background: #cbd5e1;
                border-radius: 10px;
            }

            [data-bs-theme="dark"] ::-webkit-scrollbar-thumb {
                background: #334155;
            }

            /* Tablet Responsive Shifts */
            @@media(max-width: 992px) {
                body {
                    --sidebar-width: 78px;
                }

                .brand span, .menu-title, .menu-text {
                    display: none !important;
                }

                .brand h3 {
                    justify-content: center;
                }

                .sidebar a {
                    justify-content: center;
                    padding: 12px;
                }

                .main-content {
                    margin-left: var(--sidebar-width);
                    padding: 16px;
                }
            }

            .form-engine-card {
                background: var(--bg-topbar);
                border: 1px solid var(--border-color);
                box-shadow: var(--card-shadow);
                padding: 40px; /* Increased padding for breathing room */
                margin-top: 10px;
                border-radius: 12px;
            }
            /* Force all form elements to be full width */
            .form-group, .col-12, .col-md-6 {
                width: 100% !important;
                max-width: 100% !important;
                flex: 0 0 100% !important;
                margin-bottom: 0 !important;
            }

            .form-control, .form-select {
                width: 100% !important;
                padding: 0.65rem 0.75rem !important;
            }

            .form-label {
                font-size: 13px !important;
                font-weight: 600 !important;
                text-transform: uppercase;
                color: var(--text-muted);
                margin-bottom: 8px !important;
            }

            .action-row {
                width: 100%;
                margin-top: 20px;
                padding-top: 20px;
                border-top: 1px solid var(--border-color);
                display: flex;
                gap: 10px;
            }
    </style>
</head>

<body>

    <aside class="sidebar">
        <div class="brand">
            <h3>
                <i class="fa-solid fa-shield-halved text-primary"></i>
                <span class="text-white">HMS Portal</span>
            </h3>
            <span>Management Infrastructure</span>
        </div>

        <div class="menu-title">Core Operations</div>

        <a asp-controller="Dashboard" asp-action="Index" class="@(currentController == "Dashboard" ? "active" : "")">
            <i class="fa-solid fa-chart-pie"></i>
            <span class="menu-text">Dashboard</span>
        </a>

        <a asp-controller="Students" asp-action="Index" class="@(currentController == "Students" ? "active" : "")">
            <i class="fa-solid fa-id-card"></i>
            <span class="menu-text">Students</span>
        </a>

        <a asp-controller="Hostels" asp-action="Index" class="@(currentController == "Hostels" ? "active" : "")">
            <i class="fa-solid fa-hotel"></i>
            <span class="menu-text">Hostels</span>
        </a>

        <a asp-controller="Rooms" asp-action="Index" class="@(currentController == "Rooms" ? "active" : "")">
            <i class="fa-solid fa-door-open"></i>
            <span class="menu-text">Rooms</span>
        </a>

        <a asp-controller="Beds" asp-action="Index" class="@(currentController == "Beds" ? "active" : "")">
            <i class="fa-solid fa-bed"></i>
            <span class="menu-text">Beds</span>
        </a>

        <div class="menu-title">Administration</div>

        <a asp-controller="Allocations" asp-action="Index" class="@(currentController == "Allocations" ? "active" : "")">
            <i class="fa-solid fa-clipboard-check"></i>
            <span class="menu-text">Allocations</span>
        </a>

        <a asp-controller="Payments" asp-action="Index" class="@(currentController == "Payments" ? "active" : "")">
            <i class="fa-solid fa-wallet"></i>
            <span class="menu-text">Payments</span>
        </a>

        <a asp-controller="Complaints" asp-action="Index" class="@(currentController == "Complaints" ? "active" : "")">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span class="menu-text">Complaints</span>
        </a>

        <a asp-controller="Visitors" asp-action="Index" class="@(currentController == "Visitors" ? "active" : "")">
            <i class="fa-solid fa-user-group"></i>
            <span class="menu-text">Visitors</span>
        </a>

        <a asp-controller="Staffs" asp-action="Index" class="@(currentController == "Staffs" ? "active" : "")">
            <i class="fa-solid fa-user-gear"></i>
            <span class="menu-text">Staff System</span>
        </a>

        <a asp-controller="Notices" asp-action="Index" class="@(currentController == "Notices" ? "active" : "")">
            <i class="fa-solid fa-bullhorn"></i>
            <span class="menu-text">Notices</span>
        </a>
    </aside>

    <main class="main-content">

        <div class="topbar">
            <div class="d-flex align-items-center gap-3">
                <button id="sidebarToggle" class="btn btn-light border d-none d-lg-flex align-items-center justify-content-center" style="width: 38px; height: 38px; border-radius: 8px;">
                    <i class="fa-solid fa-bars-staggered"></i>
                </button>
                <div class="page-title">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                    <span class="d-none d-sm-inline">System Engine Workspace</span>
                </div>
            </div>

            <div class="d-flex align-items-center">
                <div class="dropdown user-dropdown">
                    <a class="dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <div class="user-avatar">
                            @((currentUser?.FullName ?? "A").Substring(0, 1).ToUpper())
                        </div>
                        <div class="d-none d-md-block text-start">
                            <div class="lh-1">@(currentUser?.FullName ?? "System Administrator")</div>
                            <small class="text-muted" style="font-size: 11px;">Admin Console</small>
                        </div>
                    </a>

                    <ul class="dropdown-menu dropdown-menu-end shadow-lg">
                        <li>
                            <a class="dropdown-item" asp-controller="Admin" asp-action="Profile">
                                <i class="fa-regular fa-circle-user me-2"></i> User Profile
                            </a>
                        </li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                <i class="fa-solid fa-arrow-right-from-bracket me-2"></i> Terminate Session
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        @if (isFormView)
        {
            <div class="row justify-content-center">
                <div class="col-12 col-xl-10">
                    <div class="form-engine-card">
                        @RenderBody()
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="fade-in-content">
                @RenderBody()
            </div>
        }

    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

        // ==========================================
        // 1. COLLAPSIBLE SIDEBAR DESKTOP HANDLER
        // ==========================================
        const sidebarBtn = document.getElementById("sidebarToggle");
        if (sidebarBtn) {
        if (localStorage.getItem("sidebar-collapsed") === "true") {
        document.body.classList.add("sidebar-collapsed");
        }
        sidebarBtn.addEventListener("click", function () {
        document.body.classList.toggle("sidebar-collapsed");
        localStorage.setItem("sidebar-collapsed", document.body.classList.contains("sidebar-collapsed"));
        });
        }

        // ==========================================
        // 2. THEME CONTROLLER MODULE (LIGHT / DARK)
        // ==========================================
        const htmlElement = document.documentElement;
        const savedTheme = localStorage.getItem("theme");
        const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const initialTheme = savedTheme || (systemPrefersDark ? "dark" : "light");

        htmlElement.setAttribute("data-bs-theme", initialTheme);

        const themeToggleBtn = document.createElement("button");
        themeToggleBtn.className = "btn btn-light border me-3 d-flex align-items-center justify-content-center";
        themeToggleBtn.style.width = "38px";
        themeToggleBtn.style.height = "38px";
        themeToggleBtn.style.borderRadius = "8px";
        themeToggleBtn.setAttribute("title", "Change Interface Color Engine");

        themeToggleBtn.innerHTML = initialTheme === "dark"
        ? '<i class="fa-solid fa-sun text-warning fs-5"></i>'
        : '<i class="fa-solid fa-moon text-slate fs-5"></i>';

        const userDropdown = document.querySelector(".user-dropdown");
        if (userDropdown) {
        userDropdown.parentNode.insertBefore(themeToggleBtn, userDropdown);
        }

        themeToggleBtn.addEventListener("click", function () {
        const currentTheme = htmlElement.getAttribute("data-bs-theme");
        const newTheme = currentTheme === "dark" ? "light" : "dark";

        htmlElement.setAttribute("data-bs-theme", newTheme);
        localStorage.setItem("theme", newTheme);

        themeToggleBtn.innerHTML = newTheme === "dark"
        ? '<i class="fa-solid fa-sun text-warning fs-5"></i>'
        : '<i class="fa-solid fa-moon text-slate fs-5"></i>';
        });

        // ==========================================
        // 3. HIGH PERFORMANCE PAGINATION & TABLE ENGINE
        // ==========================================
        const ROWS_PER_PAGE = 10;

        document.querySelectorAll("table.table").forEach(function (table) {
        table.className = "table table-hover align-middle mb-0 text-nowrap";

        if (!table.closest(".table-responsive")) {
        const wrapper = document.createElement("div");
        wrapper.className = "table-responsive border shadow-sm mb-4"; // Stripped rounded-4 curvature
        table.parentNode.insertBefore(wrapper, table);
        wrapper.appendChild(table);

        // CONTROLS HEADER BAR (Search Box Alignment)
        const controlHeader = document.createElement("div");
        controlHeader.className = "d-flex justify-content-end mb-3";
        controlHeader.innerHTML = `
        <div class="input-group" style="max-width: 320px;display : -webkit-inline-box;">
        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="fa-solid fa-magnifying-glass fs-7"></i></span>
        <input type="text" class="form-control form-control-sm border-start-0 ps-0" placeholder="Search data grid...">
        </div>
        `;
        wrapper.parentNode.insertBefore(controlHeader, wrapper);

        // PAGINATION FOOTER SYSTEM INJECTION
        const paginationFooter = document.createElement("div");
        paginationFooter.className = "d-flex justify-content-between align-items-center mt-3 px-1";
        paginationFooter.innerHTML = `
        <div class="text-muted small paginator-info">Showing data range...</div>
        <nav>
        <ul class="pagination pagination-sm mb-0 custom-pagination-nodes gap-1"></ul>
        </nav>
        `;
        wrapper.parentNode.insertBefore(paginationFooter, wrapper.nextSibling);

        let activePage = 1;
        let currentFilteredRows = Array.from(table.querySelectorAll("tbody tr"));

        function renderPaginationControls() {
        const totalRows = currentFilteredRows.length;
        const totalPages = Math.ceil(totalRows / ROWS_PER_PAGE) || 1;
        const paginatorContainer = paginationFooter.querySelector(".custom-pagination-nodes");
        const infoLabel = paginationFooter.querySelector(".paginator-info");

        paginatorContainer.innerHTML = "";

        if (activePage > totalPages) activePage = totalPages;

        // Info description layout calculations
        const startIdx = totalRows === 0 ? 0 : (activePage - 1) * ROWS_PER_PAGE + 1;
        const endIdx = Math.min(activePage * ROWS_PER_PAGE, totalRows);
        infoLabel.textContent = `Showing ${startIdx} to ${endIdx} of ${totalRows} absolute entries`;

        if (totalPages <= 1) {
        paginationFooter.classList.add("d-none");
        return;
        }
        paginationFooter.classList.remove("d-none");

        // Previous Node Link
        const prevLi = document.createElement("li");
        prevLi.className = `page-item ${activePage === 1 ? "disabled" : ""}`;
        prevLi.innerHTML = `<button class="page-link border rounded-2 px-2.5" type="button"><i class="fa-solid fa-angle-left"></i></button>`;
        prevLi.addEventListener("click", () => { if(activePage > 1) { activePage--; updateGridDisplay(); } });
        paginatorContainer.appendChild(prevLi);

        // Numeric Link Matrices
        for (let i = 1; i <= totalPages; i++) {
        const li = document.createElement("li");
        li.className = `page-item ${activePage === i ? "active" : ""}`;
        li.innerHTML = `<button class="page-link border rounded-2 px-3 fw-medium ${activePage === i ? "bg-primary text-white" : "text-dark bg-light"}">${i}</button>`;
        li.addEventListener("click", () => { activePage = i; updateGridDisplay(); });
        paginatorContainer.appendChild(li);
        }

        // Next Node Link
        const nextLi = document.createElement("li");
        nextLi.className = `page-item ${activePage === totalPages ? "disabled" : ""}`;
        nextLi.innerHTML = `<button class="page-link border rounded-2 px-2.5" type="button"><i class="fa-solid fa-angle-right"></i></button>`;
        nextLi.addEventListener("click", () => { if(activePage < totalPages) { activePage++; updateGridDisplay(); } });
        paginatorContainer.appendChild(nextLi);
        }

        function updateGridDisplay() {
        const allRows = table.querySelectorAll("tbody tr");
        allRows.forEach(r => r.style.display = "none");

        const start = (activePage - 1) * ROWS_PER_PAGE;
        const end = start + ROWS_PER_PAGE;

        currentFilteredRows.slice(start, end).forEach(r => r.style.display = "");
        renderPaginationControls();
        }

        // SEARCH ENGINE CONNECTED INTEGRATION
        controlHeader.querySelector("input").addEventListener("input", function (e) {
        const val = e.target.value.toLowerCase().trim();
        const allRows = Array.from(table.querySelectorAll("tbody tr"));

        if (val === "") {
        currentFilteredRows = allRows;
        } else {
        currentFilteredRows = allRows.filter(row => {
        for (let i = 0; i < row.cells.length - 1; i++) {
        if (row.cells[i].textContent.toLowerCase().includes(val)) return true;
        }
        return false;
        });
        }
        activePage = 1;
        updateGridDisplay();
        });

        // Init Display State Engine
        updateGridDisplay();
        }

        const thead = table.querySelector("thead");
        if (thead) {
        thead.className = "table-light border-bottom text-uppercase tracking-wider";
        thead.style.fontSize = "11px";
        thead.style.fontWeight = "700";
        }

        // Status Badging Lookup Mapper
        table.querySelectorAll("td").forEach(function (cell) {
        const cellText = cell.textContent.trim();
        const lowText = cellText.toLowerCase();

        const statusStyles = {
        "active": "bg-success-subtle text-success border border-success-subtle",
        "available": "bg-success-subtle text-success border border-success-subtle",
        "occupied": "bg-primary-subtle text-primary border border-primary-subtle",
        "completed": "bg-info-subtle text-info border border-info-subtle",
        "reserved": "bg-warning-subtle text-warning border border-warning-subtle",
        "maintenance": "bg-danger-subtle text-danger border border-danger-subtle",
        "cancelled": "bg-secondary-subtle text-secondary border border-secondary-subtle",
        "pending": "bg-warning-subtle text-warning border border-warning-subtle",
        "inprogress": "bg-primary-subtle text-primary border border-primary-subtle",
        "resolved": "bg-success-subtle text-success border border-success-subtle",
        "paid": "bg-success-subtle text-success border border-success-subtle",
        "partial": "bg-warning-subtle text-warning border border-warning-subtle",
        "unpaid": "bg-danger-subtle text-danger border border-danger-subtle",
        "inactive": "bg-danger-subtle text-danger border border-danger-subtle"
        };

        if (statusStyles[lowText]) {
        cell.innerHTML = `<span class="badge rounded-pill px-2.5 py-1.5 fw-semibold ${statusStyles[lowText]}">${cellText}</span>`;
        }
        });

        // Action Row Optimization grouping rules
        table.querySelectorAll("tbody tr").forEach(function (row) {
        const lastCell = row.cells[row.cells.length - 1];
        if (lastCell && lastCell.querySelectorAll("a").length > 0) {
        const btnGroup = document.createElement("div");
        btnGroup.className = "btn-group bg-light p-0.5 rounded-2 border";

        const links = Array.from(lastCell.querySelectorAll("a"));
        links.forEach(function (a) { btnGroup.appendChild(a); });

        lastCell.innerHTML = "";
        lastCell.appendChild(btnGroup);
        lastCell.classList.add("text-end");
        }
        });
        });

        // ==========================================
        // 4. TRANSFORM SCRUD SELECTIONS INTO UTILITY ICON TOGGLES
        // ==========================================
        document.querySelectorAll("a").forEach(function (a) {
        const text = a.textContent.trim().toLowerCase();

        if (text === "create new") {
        a.className = "btn btn-primary btn-sm px-3 fw-semibold shadow-sm mb-3";
        a.innerHTML = '<i class="fa-solid fa-plus me-1.5 fs-7"></i> Create New Ledger';
        }
        else if (text === "edit") {
        a.className = "btn btn-link link-dark text-decoration-none px-2 py-1 fs-7";
        a.innerHTML = '<i class="fa-solid fa-user-pen text-primary" title="Modify Record"></i>';
        }
        else if (text === "details") {
        a.className = "btn btn-link link-dark text-decoration-none px-2 py-1 fs-7";
        a.innerHTML = '<i class="fa-solid fa-circle-info text-info" title="Inspect Record"></i>';
        }
        else if (text === "delete") {
        a.className = "btn btn-link link-dark text-decoration-none px-2 py-1 fs-7";
        a.innerHTML = '<i class="fa-solid fa-trash-can text-danger" title="Purge Record"></i>';
        }
        else if (text === "back to list") {
        a.className = "btn btn-light border btn-sm fw-medium mt-3";
        a.innerHTML = '<i class="fa-solid fa-chevron-left me-1.5"></i> Return to Console';
        }
        });

        // ==========================================
        // 5. DATA FIELD FORM RE-ENGINEERING (Create / Edit View Optimization)
        // ==========================================
        const form = document.querySelector(".form-engine-card form");
        if (form) {
        // Re-map row container to force grid design structure for scaffolding layout
        let rowWrapper = form.querySelector(".row");
        if (!rowWrapper) {
        rowWrapper = document.createElement("div");
        rowWrapper.className = "row g-3";

        const formGroups = Array.from(form.querySelectorAll(".form-group, div[class*='mb-']"));
        if(formGroups.length > 0) {
        formGroups[0].parentNode.insertBefore(rowWrapper, formGroups[0]);
        formGroups.forEach(group => {
        if(!group.querySelector("input[type='submit']")) {
        rowWrapper.appendChild(group);
        }
        });
        }
        } else {
        rowWrapper.classList.add("g-3");
        }

        // Uniformly format inputs and split fields into highly-scannable 2-column configurations
        form.querySelectorAll("input:not([type='submit']):not([type='checkbox']):not([type='radio']), select, textarea").forEach(function (input) {
        input.className = "form-control form-control-sm rounded-2";

        const group = input.closest(".form-group") || input.parentElement;
        if (group && !group.classList.contains("col-md-6") && !group.classList.contains("col-12")) {
        group.className = "col-6 col-md-6 mb-2";
        }

        // Map labels above inputs beautifully
        const label = group.querySelector("label");
        if (label) {
        label.className = "form-label";
        }
        });

        // Isolate action execution buttons into clean bottom positioning rows
        const submitBtn = form.querySelector("input[type='submit'], button[type='submit']");
        if (submitBtn) {
        submitBtn.className = "btn btn-primary btn-sm px-4 fw-semibold shadow-sm";

        const actionContainer = document.createElement("div");
        actionContainer.className = "col-12 d-flex justify-content-start gap-2 mt-4 pt-3 border-top";

        submitBtn.parentNode.insertBefore(actionContainer, submitBtn);
        actionContainer.appendChild(submitBtn);

        // Pull back-to-list navigation elements right next to the save execution buttons
        const backBtn = document.querySelector(".form-engine-card a.btn-light");
        if (backBtn) {
        backBtn.classList.remove("mt-3");
        actionContainer.appendChild(backBtn);
        }
        }
        }

        });
    </script>
    @RenderSection("Scripts", required: false)

</body>
</html>