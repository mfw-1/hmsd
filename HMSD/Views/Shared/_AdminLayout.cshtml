@using Microsoft.AspNetCore.Identity
@using HMSD.Data

@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = await UserManager.GetUserAsync(User);
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Hostel Management System</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                background: #f4f7fe;
                font-family: 'Segoe UI', sans-serif;
                overflow-x: hidden;
            }

            /* =========================
                       SIDEBAR
                    ==========================*/

            .sidebar {
                width: 260px;
                height: 100vh;
                position: fixed;
                left: 0;
                top: 0;
                background: linear-gradient(180deg, #111827, #1f2937);
                color: white;
                padding: 20px 0;
                z-index: 1000;
                overflow-y: auto;
            }

            .brand {
                padding: 0 20px 20px;
                border-bottom: 1px solid rgba(255,255,255,0.08);
                margin-bottom: 20px;
            }

                .brand h3 {
                    font-size: 22px;
                    font-weight: 700;
                    margin: 0;
                    color: white;
                }

                .brand span {
                    color: #9ca3af;
                    font-size: 13px;
                }

            .menu-title {
                color: #9ca3af;
                font-size: 12px;
                text-transform: uppercase;
                padding: 10px 20px;
                margin-top: 10px;
                letter-spacing: 1px;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                color: #d1d5db;
                text-decoration: none;
                padding: 13px 20px;
                margin: 6px 12px;
                border-radius: 12px;
                transition: 0.3s;
                font-size: 15px;
                font-weight: 500;
            }

                .sidebar a:hover {
                    background: rgba(255,255,255,0.08);
                    color: white;
                    transform: translateX(3px);
                }

                .sidebar a.active {
                    background: linear-gradient(90deg, #2563eb, #3b82f6);
                    color: white;
                    box-shadow: 0 4px 12px rgba(59,130,246,0.3);
                }

                .sidebar a i {
                    width: 22px;
                    text-align: center;
                    font-size: 16px;
                }

            /* =========================
                       MAIN CONTENT
                    ==========================*/

            .main-content {
                margin-left: 260px;
                min-height: 100vh;
                padding: 25px;
            }

            /* =========================
                       TOPBAR
                    ==========================*/

            .topbar {
                background: white;
                border-radius: 18px;
                padding: 16px 24px;
                margin-bottom: 25px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                box-shadow: 0 2px 15px rgba(0,0,0,0.05);
            }

            .page-title h4 {
                margin: 0;
                font-size: 24px;
                font-weight: 700;
                color: #111827;
            }

            .page-title span {
                font-size: 13px;
                color: #6b7280;
            }

            /* =========================
                       USER DROPDOWN
                    ==========================*/

            .user-dropdown .dropdown-toggle {
                text-decoration: none;
                color: #111827;
                display: flex;
                align-items: center;
                gap: 12px;
                font-weight: 600;
            }

            .user-avatar {
                width: 42px;
                height: 42px;
                background: linear-gradient(135deg, #2563eb, #3b82f6);
                border-radius: 50%;
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 18px;
            }

            .dropdown-menu {
                border: none;
                border-radius: 14px;
                padding: 10px;
                box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            }

            .dropdown-item {
                border-radius: 10px;
                padding: 10px 14px;
                font-size: 14px;
            }

                .dropdown-item:hover {
                    background: #f3f4f6;
                }

            /* =========================
                       CARDS
                    ==========================*/

            .dashboard-card {
                border: none;
                border-radius: 20px;
                overflow: hidden;
                box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            }

            /* =========================
                       TABLES
                    ==========================*/

            .table {
                vertical-align: middle;
            }

                .table thead {
                    background: #f9fafb;
                }

            /* =========================
                       SCROLLBAR
                    ==========================*/

            ::-webkit-scrollbar {
                width: 8px;
            }

            ::-webkit-scrollbar-thumb {
                background: #d1d5db;
                border-radius: 20px;
            }

            /* =========================
                       MOBILE
                    ==========================*/

            @@media(max-width: 992px) {

                .sidebar {
                    width: 85px;
                }

                    .sidebar .menu-text,
                    .brand span,
                    .menu-title {
                        display: none;
                    }

                .main-content {
                    margin-left: 85px;
                }

                .brand h3 {
                    text-align: center;
                    font-size: 18px;
                }

                .sidebar a {
                    justify-content: center;
                }
            }

    </style>

</head>

<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <div class="brand">
            <h3>
                <i class="fa-solid fa-building"></i>
                HMS
            </h3>

            <span>Hostel Management System</span>
        </div>

        <div class="menu-title">Main Menu</div>

        <a asp-controller="Dashboard"
           asp-action="Index"
           class="@(currentController == "Dashboard" ? "active" : "")">

            <i class="fa-solid fa-chart-line"></i>
            <span class="menu-text">Dashboard</span>
        </a>

        <a asp-controller="Students"
           asp-action="Index"
           class="@(currentController == "Students" ? "active" : "")">

            <i class="fa-solid fa-user-graduate"></i>
            <span class="menu-text">Students</span>
        </a>

        <a asp-controller="Hostels"
           asp-action="Index"
           class="@(currentController == "Hostels" ? "active" : "")">

            <i class="fa-solid fa-building"></i>
            <span class="menu-text">Hostels</span>
        </a>

        <a asp-controller="Rooms"
           asp-action="Index"
           class="@(currentController == "Rooms" ? "active" : "")">

            <i class="fa-solid fa-bed"></i>
            <span class="menu-text">Rooms</span>
        </a>

        <a asp-controller="Beds"
           asp-action="Index"
           class="@(currentController == "Beds" ? "active" : "")">

            <i class="fa-solid fa-bed-pulse"></i>
            <span class="menu-text">Beds</span>
        </a>

        <a asp-controller="Allocations"
           asp-action="Index"
           class="@(currentController == "Allocations" ? "active" : "")">

            <i class="fa-solid fa-handshake"></i>
            <span class="menu-text">Allocations</span>
        </a>

        <a asp-controller="Payments"
           asp-action="Index"
           class="@(currentController == "Payments" ? "active" : "")">

            <i class="fa-solid fa-money-bill-wave"></i>
            <span class="menu-text">Payments</span>
        </a>

        <a asp-controller="Complaints"
           asp-action="Index"
           class="@(currentController == "Complaints" ? "active" : "")">

            <i class="fa-solid fa-circle-exclamation"></i>
            <span class="menu-text">Complaints</span>
        </a>

        <a asp-controller="Visitors"
           asp-action="Index"
           class="@(currentController == "Visitors" ? "active" : "")">

            <i class="fa-solid fa-users"></i>
            <span class="menu-text">Visitors</span>
        </a>

        <a asp-controller="Staffs"
           asp-action="Index"
           class="@(currentController == "Staffs" ? "active" : "")">

            <i class="fa-solid fa-user-tie"></i>
            <span class="menu-text">Staff</span>
        </a>

        <a asp-controller="Notices"
           asp-action="Index"
           class="@(currentController == "Notices" ? "active" : "")">

            <i class="fa-solid fa-bell"></i>
            <span class="menu-text">Notices</span>
        </a>

    </aside>

    <!-- MAIN -->
    <main class="main-content">

        <!-- TOPBAR -->
        <div class="topbar">

            <div class="page-title">
                <h4>@ViewData["Title"]</h4>
                <span>Hostel Management Administration Panel</span>
            </div>

            <!-- USER -->
            <div class="dropdown user-dropdown">

                <a class="dropdown-toggle"
                   href="#"
                   data-bs-toggle="dropdown">

                    <div class="user-avatar">
                        <i class="fa-solid fa-user"></i>
                    </div>

                    <div>
                        <div style="font-size:14px;">
                            @(currentUser?.FullName ?? "Admin")
                        </div>

                        <small class="text-muted">
                            Administrator
                        </small>
                    </div>

                </a>

                <ul class="dropdown-menu dropdown-menu-end">

                    <li>
                        <a class="dropdown-item"
                           asp-controller="Admin"
                           asp-action="Profile">

                            <i class="fa-solid fa-user me-2"></i>
                            My Profile
                        </a>
                    </li>

                    <li>
                        <hr class="dropdown-divider" />
                    </li>

                    <li>
                        <a class="dropdown-item text-danger"
                           asp-controller="Account"
                           asp-action="Logout">

                            <i class="fa-solid fa-right-from-bracket me-2"></i>
                            Logout
                        </a>
                    </li>

                </ul>

            </div>

        </div>

        <!-- PAGE CONTENT -->
        @RenderBody()

    </main>

    <!-- Bootstrap -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>