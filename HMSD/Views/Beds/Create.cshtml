@model HMSD.Data.Bed

@{
    ViewData["Title"] = "Create Bed";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Create Bed</h2>
            <small class="text-muted">Add a new bed to a room</small>
        </div>

        <a asp-action="Index" class="btn btn-light border shadow-sm">
            ← Back
        </a>
    </div>

    <!-- Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4 p-md-5">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <!-- ROOM INFO -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Room Assignment</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="RoomId" class="form-label fw-semibold"></label>
                            <select asp-for="RoomId"
                                    class="form-select form-select-lg shadow-sm"
                                    asp-items="ViewBag.RoomId"></select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="BedNumber" class="form-label fw-semibold"></label>
                            <input asp-for="BedNumber"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="e.g. Bed A1 / B2" />
                            <span asp-validation-for="BedNumber" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- STATUS -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Status</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status"
                                    class="form-select form-select-lg shadow-sm"></select>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SYSTEM -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">System Info</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="CreatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="CreatedAt"
                                   type="datetime-local"
                                   class="form-control shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="UpdatedAt"
                                   type="datetime-local"
                                   class="form-control shadow-sm" />
                        </div>

                    </div>
                </div>

                <!-- BUTTONS -->
                <div class="d-flex justify-content-end gap-2 mt-4">

                    

                    <button type="submit" class="btn btn-primary px-5 shadow">
                        Create Bed
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}