@model HMSD.Data.Staff

@{
    ViewData["Title"] = "Create Staff";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Create Staff Member</h2>
            <small class="text-muted">Add new employee to hostel management system</small>
        </div>

        <a asp-action="Index" class="btn btn-light border shadow-sm">
            ← Back
        </a>
    </div>

    <!-- Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4 p-md-5">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <!-- PERSONAL INFO -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Personal Information</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="Full name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label fw-semibold"></label>
                            <input asp-for="Role"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="e.g. Warden / Accountant / Guard" />
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- CONTACT INFO -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Contact Information</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label fw-semibold"></label>
                            <input asp-for="Phone"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="03XX-XXXXXXX" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email"
                                   type="email"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="example@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- JOB INFO -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Job Details</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="Salary" class="form-label fw-semibold"></label>

                            <div class="input-group input-group-lg shadow-sm">
                                <span class="input-group-text">PKR</span>
                                <input asp-for="Salary" class="form-control" />
                            </div>

                            <span asp-validation-for="Salary" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="JoiningDate" class="form-label fw-semibold"></label>
                            <input asp-for="JoiningDate"
                                   type="date"
                                   class="form-control form-control-lg shadow-sm" />
                            <span asp-validation-for="JoiningDate" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- STATUS -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Status</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status"
                                    class="form-select form-select-lg shadow-sm"></select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SYSTEM -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">System Info</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="CreatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="CreatedAt"
                                   type="datetime-local"
                                   class="form-control shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="UpdatedAt"
                                   type="datetime-local"
                                   class="form-control shadow-sm" />
                        </div>

                    </div>
                </div>

                <!-- BUTTONS -->
                <div class="d-flex justify-content-end gap-2 mt-4">

                    <button type="submit" class="btn btn-success px-5 shadow">
                        Create Staff
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}