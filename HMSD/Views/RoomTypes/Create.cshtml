@model HMSD.Data.RoomType

@{
    ViewData["Title"] = "Create Room Type";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Create Room Type</h2>
            <small class="text-muted">Define room category, capacity and pricing</small>
        </div>

        <a asp-action="Index" class="btn btn-light border shadow-sm">
            ← Back
        </a>
    </div>

    <!-- Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4 p-md-5">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <!-- BASIC INFO -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Basic Information</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="e.g. Single / Double / VIP Room" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Capacity" class="form-label fw-semibold"></label>
                            <input asp-for="Capacity"
                                   type="number"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="Number of beds" />
                            <span asp-validation-for="Capacity" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- PRICING -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Pricing</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="MonthlyRent" class="form-label fw-semibold"></label>

                            <div class="input-group input-group-lg shadow-sm">
                                <span class="input-group-text">PKR</span>
                                <input asp-for="MonthlyRent" class="form-control" />
                            </div>

                            <span asp-validation-for="MonthlyRent" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- DESCRIPTION -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Description</h6>

                    <textarea asp-for="Description"
                              class="form-control shadow-sm"
                              rows="3"
                              placeholder="Optional details about room type..."></textarea>

                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <hr class="my-4" />

                <!-- SYSTEM INFO -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">System Info</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="CreatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="CreatedAt"
                                   type="datetime-local"
                                   class="form-control shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="UpdatedAt"
                                   type="datetime-local"
                                   class="form-control shadow-sm" />
                        </div>

                    </div>
                </div>

                <!-- BUTTONS -->
                <div class="d-flex justify-content-end gap-2 mt-4">

                    <a asp-action="Index" class="btn btn-light border px-4">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary px-5 shadow">
                        Create Room Type
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}