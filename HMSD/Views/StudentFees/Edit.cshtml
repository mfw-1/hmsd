@model HMSD.Data.StudentFee

@{
    ViewData["Title"] = "Edit Student Fee";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Edit Student Fee</h2>
            <small class="text-muted">Update billing record and payment details</small>
        </div>

        <a asp-action="Index" class="btn btn-light border shadow-sm">
            ← Back
        </a>
    </div>

    <!-- Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4 p-md-5">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <!-- STUDENT INFO -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Student Information</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="StudentId" class="form-label fw-semibold"></label>
                            <select asp-for="StudentId"
                                    class="form-select form-select-lg shadow-sm"
                                    asp-items="ViewBag.StudentId"></select>
                            <span asp-validation-for="StudentId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="FeeTypeId" class="form-label fw-semibold"></label>
                            <select asp-for="FeeTypeId"
                                    class="form-select form-select-lg shadow-sm"
                                    asp-items="ViewBag.FeeTypeId"></select>
                            <span asp-validation-for="FeeTypeId" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- BILLING -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Billing Details</h6>

                    <div class="row g-4">

                        <div class="col-md-4">
                            <label asp-for="Amount" class="form-label fw-semibold"></label>

                            <div class="input-group input-group-lg shadow-sm">
                                <span class="input-group-text">PKR</span>
                                <input asp-for="Amount" class="form-control" />
                            </div>

                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Month" class="form-label fw-semibold"></label>
                            <input asp-for="Month" class="form-control form-control-lg shadow-sm" />
                            <span asp-validation-for="Month" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Year" class="form-label fw-semibold"></label>
                            <input asp-for="Year" type="number" class="form-control form-control-lg shadow-sm" />
                            <span asp-validation-for="Year" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- PAYMENT STATUS -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Payment Status</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="DueDate" class="form-label fw-semibold"></label>
                            <input asp-for="DueDate" type="date" class="form-control form-control-lg shadow-sm" />
                            <span asp-validation-for="DueDate" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <select asp-for="Status" class="form-select form-select-lg shadow-sm"></select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SYSTEM INFO -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">System Information</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="CreatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="CreatedAt" class="form-control shadow-sm" readonly />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="UpdatedAt" type="datetime-local" class="form-control shadow-sm" />
                        </div>

                    </div>
                </div>

                <!-- Hidden -->
                <input type="hidden" asp-for="Id" />

                <!-- BUTTONS -->
                <div class="d-flex justify-content-end gap-2 mt-4">

                    <a asp-action="Index" class="btn btn-light border px-4">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary px-5 shadow">
                        Save Changes
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}