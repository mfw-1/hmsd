@model HMSD.Data.Visitor

@{
    ViewData["Title"] = "Edit Visitor";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Edit Visitor</h2>
            <small class="text-muted">Update visitor information and visit details</small>
        </div>

        <a asp-action="Index" class="btn btn-light border shadow-sm">
            ← Back
        </a>
    </div>

    <!-- Main Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4 p-md-5">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger py-2"></div>

                <input type="hidden" asp-for="Id" />

                <!-- SECTION 1 -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">
                        Student Information
                    </h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="StudentId"
                                   class="form-label fw-semibold"></label>

                            <select asp-for="StudentId"
                                    class="form-select form-select-lg shadow-sm"
                                    asp-items="ViewBag.StudentId">
                            </select>

                            <span asp-validation-for="StudentId"
                                  class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SECTION 2 -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">
                        Visitor Details
                    </h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="VisitorName"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="VisitorName"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="Visitor Name" />

                            <span asp-validation-for="VisitorName"
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Relation"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="Relation"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="Relation with Student" />

                            <span asp-validation-for="Relation"
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Phone"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="Phone"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="Phone Number" />

                            <span asp-validation-for="Phone"
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Purpose"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="Purpose"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="Purpose of Visit" />

                            <span asp-validation-for="Purpose"
                                  class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SECTION 3 -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">
                        Visit Timing
                    </h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="CheckInTime"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="CheckInTime"
                                   type="datetime-local"
                                   class="form-control form-control-lg shadow-sm" />

                            <span asp-validation-for="CheckInTime"
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CheckOutTime"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="CheckOutTime"
                                   type="datetime-local"
                                   class="form-control form-control-lg shadow-sm" />

                            <span asp-validation-for="CheckOutTime"
                                  class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SECTION 4 -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">
                        Record Information
                    </h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="CreatedAt"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="CreatedAt"
                                   type="datetime-local"
                                   class="form-control form-control-lg shadow-sm" />

                            <span asp-validation-for="CreatedAt"
                                  class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdatedAt"
                                   class="form-label fw-semibold"></label>

                            <input asp-for="UpdatedAt"
                                   type="datetime-local"
                                   class="form-control form-control-lg shadow-sm" />

                            <span asp-validation-for="UpdatedAt"
                                  class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <!-- ACTIONS -->
                <div class="d-flex justify-content-end mt-4">


                    <button type="submit"
                            class="btn btn-primary btn-lg px-5 shadow">
                        Save Changes
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}