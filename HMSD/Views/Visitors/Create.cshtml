@model HMSD.Data.Visitor

@{
    ViewData["Title"] = "Create Visitor";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Create Visitor</h4>
                </div>

                <div class="card-body">
                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="StudentId" class="form-label"></label>
                            <select asp-for="StudentId" class="form-select" asp-items="ViewBag.StudentId"></select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="VisitorName" class="form-label"></label>
                            <input asp-for="VisitorName" class="form-control" />
                            <span asp-validation-for="VisitorName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Relation" class="form-label"></label>
                            <input asp-for="Relation" class="form-control" />
                            <span asp-validation-for="Relation" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label"></label>
                            <input asp-for="Phone" class="form-control" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CheckInTime" class="form-label"></label>
                            <input asp-for="CheckInTime" class="form-control" />
                            <span asp-validation-for="CheckInTime" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CheckOutTime" class="form-label"></label>
                            <input asp-for="CheckOutTime" class="form-control" />
                            <span asp-validation-for="CheckOutTime" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Purpose" class="form-label"></label>
                            <input asp-for="Purpose" class="form-control" />
                            <span asp-validation-for="Purpose" class="text-danger"></span>
                        </div>

                        <div class="flex justify-content-end gap-2">
                            
                            <button type="submit" class="btn btn-primary">Create</button>
                        </div>
                        <a asp-action="Index" class="btn btn-outline-secondary mt-1">Back</a>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}