@model HMSD.Data.Hostel

@{
    ViewData["Title"] = "Edit Hostel";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Edit Hostel</h2>
            <small class="text-muted">Update hostel details</small>
        </div>

        <a asp-action="Index" class="btn btn-light border shadow-sm">
            ← Back
        </a>
    </div>

    <!-- Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4 p-md-5">

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <!-- BASIC INFO -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Basic Information</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label fw-semibold"></label>
                            <input asp-for="Name"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="e.g. Boys Hostel / Girls Hostel" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="GenderType" class="form-label fw-semibold"></label>
                            <input asp-for="GenderType"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="Male / Female / Co-Ed" />
                            <span asp-validation-for="GenderType" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- STRUCTURE -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Structure Details</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="Address" class="form-label fw-semibold"></label>
                            <input asp-for="Address"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="Full hostel address" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="TotalRooms" class="form-label fw-semibold"></label>
                            <input asp-for="TotalRooms"
                                   type="number"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="e.g. 50" />
                            <span asp-validation-for="TotalRooms" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- DESCRIPTION -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Description</h6>

                    <div class="row g-4">

                        <div class="col-12">
                            <textarea asp-for="Description"
                                      class="form-control shadow-sm"
                                      rows="4"
                                      placeholder="Update hostel description..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SYSTEM -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">System Info</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="CreatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="CreatedAt"
                                   type="datetime-local"
                                   class="form-control shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="UpdatedAt"
                                   type="datetime-local"
                                   class="form-control shadow-sm" />
                        </div>

                    </div>
                </div>

                <!-- Hidden ID -->
                <input type="hidden" asp-for="Id" />

                <!-- BUTTONS -->
                <div class="d-flex justify-content-end gap-2 mt-4">

                    

                    <button type="submit" class="btn btn-primary px-5 shadow">
                        Save Changes
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}