@model HMSD.Data.Attendance

@{
    ViewData["Title"] = "Create Attendance";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Create Attendance</h2>
            <small class="text-muted">Mark student attendance record</small>
        </div>

        <a asp-action="Index" class="btn btn-light border shadow-sm">
            ← Back
        </a>
    </div>

    <!-- Card -->
    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4 p-md-5">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                <!-- STUDENT -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Student Info</h6>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="StudentId" class="form-label fw-semibold"></label>
                            <select asp-for="StudentId"
                                    class="form-select form-select-lg shadow-sm"
                                    asp-items="ViewBag.StudentId"></select>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <!-- ATTENDANCE DETAILS -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">Attendance Details</h6>

                    <div class="row g-4">

                        <div class="col-md-4">
                            <label asp-for="Date" class="form-label fw-semibold"></label>
                            <input asp-for="Date"
                                   type="date"
                                   class="form-control shadow-sm" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="CheckInTime" class="form-label fw-semibold"></label>
                            <input asp-for="CheckInTime"
                                   type="time"
                                   class="form-control shadow-sm" />
                        </div>

                        <div class="col-md-4">
                            <label asp-for="CheckOutTime" class="form-label fw-semibold"></label>
                            <input asp-for="CheckOutTime"
                                   type="time"
                                   class="form-control shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label fw-semibold"></label>
                            <input asp-for="Status"
                                   class="form-control form-control-lg shadow-sm"
                                   placeholder="Present / Absent / Late" />
                        </div>

                    </div>
                </div>

                <hr class="my-4" />

                <!-- SYSTEM -->
                <div class="mb-4">
                    <h6 class="text-uppercase text-muted fw-semibold mb-3">System Info</h6>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="CreatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="CreatedAt"
                                   type="datetime-local"
                                   class="form-control shadow-sm" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdatedAt" class="form-label fw-semibold"></label>
                            <input asp-for="UpdatedAt"
                                   type="datetime-local"
                                   class="form-control shadow-sm" />
                        </div>

                    </div>
                </div>

                <!-- BUTTONS -->
                <div class="d-flex justify-content-end gap-2 mt-4">

                    <a asp-action="Index" class="btn btn-light border px-4">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary px-5 shadow">
                        Save Attendance
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}